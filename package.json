{
  "name": "milassoc-pro",
  "version": "5.2.0",
  "description": "Application de gestion d'association militaire",
  "type": "module",
  "main": "server/server.js",
  "scripts": {
    "dev": "npx serve public -p 3000",
    "build": "npm run build:css && npm run build:js",
    "build:css": "npx tailwindcss -i public/css/main.css -o public/css/dist/main.min.css --minify",
    "build:js": "npx esbuild public/js/*.js --bundle --minify --outdir=public/js/dist",
    "start": "node server/server.js",
    "test": "npm run test:unit",
    "test:unit": "node --test tests/unit/*.test.js",
    "test:e2e": "npx playwright test",
    "lint": "npx eslint public/js/ server/",
    "lint:fix": "npm run lint -- --fix",
    "precommit": "npm run lint && npm run test:unit"
  },
  "keywords": [
    "association",
    "militaire",
    "gestion",
    "membres",
    "événements",
    "finances"
  ],
  "author": "Frederic Massez",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fmassez/MilAssoc-Pro"
  },
  "dependencies": {
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "tailwindcss": "^3.3.5",
    "esbuild": "^0.19.8",
    "eslint": "^8.55.0",
    "playwright": "^1.40.0",
    "serve": "^14.2.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}